---
import { format } from 'date-fns';

interface Props {
  title: string;
  description: string;
  dateOfPost: Date;
}

const { title, description, dateOfPost } = Astro.props;
---

<div class="blog-card">
  <div class="blog-card-date">
    {format(new Date(dateOfPost), 'MMM d, yyyy')}
  </div>
  <h3 class="blog-card-title">{title}</h3>
  <p class="blog-card-description">{description}</p>
</div>

<style>
  .blog-card {
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .blog-card-date {
    font-size: 0.8rem;
    color: var(--color-text-tertiary);
    margin-bottom: 0.25rem;
  }

  .blog-card-title {
    margin: 0;
    font-size: 1.1rem;
    font-weight: normal;
    line-height: 1.3;
    color: var(--color-text);
  }

  .blog-card-description {
    margin: 0.5rem 0 0;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }
</style>
