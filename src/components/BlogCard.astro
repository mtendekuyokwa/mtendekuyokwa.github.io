---
import { format } from 'date-fns';

interface Props {
  title: string;
  description: string;
  dateOfPost: Date;
}

const { title, description, dateOfPost } = Astro.props;
---

<div class="blog-card">
  <div class="blog-card-date">
    {format(new Date(dateOfPost), 'MMM d, yyyy')}
  </div>
  <div class="blog-card-content">
    <h3 class="blog-card-title">{title}</h3>
    <p class="blog-card-description">{description}</p>
  </div>
</div>

<style>
  .blog-card {
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--bg);
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    height: 100%;
  }

  .blog-card:hover {
    border-color: var(--accent);
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.1);
    transform: translateY(-2px);
  }

  .blog-card-date {
    font-size: 0.85rem;
    color: var(--text-tertiary);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .blog-card-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .blog-card-title {
    margin: 0;
    font-size: 1.25rem;
    line-height: 1.3;
    color: var(--text);
    transition: color 0.2s ease;
  }

  .blog-card:hover .blog-card-title {
    color: var(--accent);
  }

  .blog-card-description {
    margin: 0;
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  @media (max-width: 640px) {
    .blog-card {
      padding: 1rem;
    }

    .blog-card-title {
      font-size: 1.1rem;
    }

    .blog-card-description {
      font-size: 0.9rem;
    }
  }
</style>
