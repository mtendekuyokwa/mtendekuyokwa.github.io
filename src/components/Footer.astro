---
const today = new Date();
---

<footer class="footer-bar">
  <div class="footer-bar-content">
    <p>&copy; {today.getFullYear()} Mtende Kuyokwa. All rights reserved.</p>
  </div>
</footer>

<style>
  .footer-bar {
    border-top: 1px solid var(--border);
    background: var(--bg);
    padding: 1.5rem 2rem;
    margin-top: auto;
  }

  .footer-bar-content {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .footer-bar p {
    font-size: 0.9rem;
    color: var(--text-tertiary);
    margin: 0;
    text-align: center;
  }

  @media (max-width: 768px) {
    .footer-bar {
      padding: 1rem 1.5rem;
    }

    .footer-bar p {
      font-size: 0.85rem;
    }
  }

  @media (max-width: 480px) {
    .footer-bar {
      padding: 0.75rem 1rem;
    }

    .footer-bar p {
      font-size: 0.8rem;
    }
  }
</style>
