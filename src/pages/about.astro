---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_AUTHOR, SOCIAL_LINKS } from '../consts';
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`${SITE_AUTHOR} - About`}
      description="About Mtende Kuyokwa."
    />
  </head>
  <body>
    <Header currentPath="/about" />

    <main class="max-w-2xl mx-auto px-4 py-8">
      <h1 class="text-xl font-normal mb-8">About</h1>

      <div class="space-y-6 text-base leading-relaxed">
        <p>
          I'm {SITE_AUTHOR}, a student at the Malawi University of Business and Applied Science. I build tools that solve real problems and write about what I learn along the way.
        </p>

        <p>
          I'm currently working on <a href="#">Jiya</a>. I'm interested in the space between product, design, and technology.
        </p>

        <h2 class="text-base font-normal mt-10 mb-4">Contact</h2>

        <p>
          <a href={SOCIAL_LINKS.email}>Email</a> /
          <a href={SOCIAL_LINKS.github}>GitHub</a> /
          <a href={SOCIAL_LINKS.twitter}>Twitter</a>
        </p>
      </div>
    </main>

    <Footer />
  </body>
</html>
