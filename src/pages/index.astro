---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import "../styles/global.css";
import finnImg from "/src/assets/images/finn.png";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
   <body class="flex p-9  items-center  justify-center   ">
      <div class="w-2/4 flex justify-between flex-col min-h-screen">

		<Header />
		<main class="flex gap-5 flex-col">
         <div>
            <div>
               <Image src={finnImg} alt="Finn from adveture time" width={100} height={100} />
            </div>
         <h1 class="font-bold text-4xl">
            Hello!, I'm Mtende
         </h1>
			<p class="text-justify">
         I am a student at the Malawi University of Business and Applied Science. When I am not in class, I work on my app, Jiya. I would love if you would try it out.   
			</p>
			<p class="text-justify">
         I write about my endovours and explorations in my thought chamber. Do make a visit also.
			</p>

         </div>
         <div class="flex flex-col">
            <div class="flex justify-between">
               <h3 class="text-xl font-bold">Thought chamber</h3>
               <button class="outline-1 rounded-md p-1">All Neurons</button>
            </div>
            <ul>

            </ul>
         </div>
		</main>
		<Footer />

      </div>
	</body>
</html>
