---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_AUTHOR } from '../consts';
import { getCollection } from 'astro:content';
import '../styles/global.css';
import {Image} from 'astro:assets'

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const recentPosts = allPosts.slice(0, 5);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  </head>
  <body>
    <Header currentPath="/" />

    <main class="max-w-2xl mx-auto px-4 py-8">

      <section class="mb-16">
        <div class="flex items-baseline">

        <h1 class="text-xl font-normal mb-4">{SITE_AUTHOR}</h1>
        <Image src="https://upload.wikimedia.org/wikipedia/commons/thumb/a/a6/Finn_the_Human_character.svg/250px-Finn_the_Human_character.svg.png" alt="A bird." width="70" height="70" />
        </div>
        <p class="text-base leading-relaxed mb-3">
        <p>
          I'm {SITE_AUTHOR}, a student at the Malawi University of Business and Applied Science. 
        </p>
        <p>
        I'm currently working on <a href="https://play.google.com/store/apps/details?id=com.mtendekuyokwa.jiya&pcampaignid=web_share">Jiya</a>. Jiya is a ridesharing app for Malawi. 
        </p>
        </p>
        <p class="text-base leading-relaxed mb-4">
          <a href="https://github.com/mtendekuyokwa">GitHub</a> /
          <a href="https://twitter.com/mtende_kuyokwa">Twitter</a> /
          <a href="mailto:mtendekuyokwa19@gmail.com">Email</a>
        </p>
      </section>

      <section>
        <h2 class="text-base font-normal mb-6">Recent Essays</h2>
        <ul class="space-y-3">
          {recentPosts.map((post) => (
            <li class="flex justify-between items-baseline">
              <a href={`/blog/${post.id}/`} class="hover:underline">{post.data.title}</a>
              <span class="text-sm text-text-tertiary ml-4 whitespace-nowrap">{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
            </li>
          ))}
        </ul>
        <p class="mt-6 text-sm">
          <a href="/blog">All essays &rarr;</a>
        </p>
      </section>
    </main>

    <Footer />
  </body>
</html>
